# ---- Core Django ----
DEBUG=True
SECRET_KEY=dev-insecure-change-me-in-prod
# Comma-separated. Only used when DEBUG=False.
# Cloudflare Pages preview branches use the pattern <branch>-<project>.workers.dev
# — the leading dot wildcard covers every preview deploy.
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,.swaadkidukaanfront.prafullkumar384.workers.dev

# ---- CORS (frontend origins). Comma-separated absolute origins. ----
# Apex Cloudflare Pages deployment:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://swaadkidukaanfront.prafullkumar384.workers.dev
# Preview branches (`<branch>-swaadkidukaanfront.prafullkumar384.workers.dev`)
# matched by regex so every Cloudflare Pages preview is allowed automatically.
CORS_ALLOWED_ORIGIN_REGEXES=^https://[a-z0-9-]+-swaadkidukaanfront\.prafullkumar384\.workers\.dev$

# ---- Client signature guard ----
# In DEBUG you can bypass so Swagger/Postman can be used locally.
REQUIRE_SIGNATURE=False
APP_SIGNATURE_SECRET=change-me-shared-secret
# Max age (seconds) for the X-Client-Timestamp anti-replay window.
SIGNATURE_MAX_AGE=300

# ---- Rate limiting (PROD only; disabled entirely when DEBUG=True) ----
# Generous by design so genuine users are never locked out.
THROTTLE_ANON=300/min
THROTTLE_SEND_OTP=10/min
THROTTLE_VERIFY_OTP=20/min
THROTTLE_MENU=120/min

# ---- Geofence ----
RESTAURANT_LAT=29.04039
RESTAURANT_LNG=77.67525
DELIVERY_RADIUS_KM=10.0

# ---- Firebase (choose ONE) ----
# Whole service-account JSON as a single-line string:
FIREBASE_CREDENTIALS_JSON=
# ...or a path to the service-account file:
GOOGLE_APPLICATION_CREDENTIALS=

# ---- WhatsApp (prod mock placeholders) ----
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
